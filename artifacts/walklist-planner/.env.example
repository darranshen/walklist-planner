# Google Maps API Key
# Required for interactive map, geocoding addresses, and walking time calculations.
# Enable these APIs in Google Cloud Console:
#   - Maps JavaScript API
#   - Directions API
#   - Geocoding API
#
# Without this key, the app runs in demo mode with the sample route and estimated times.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
